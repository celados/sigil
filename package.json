{
	"name": "sigil",
	"version": "0.1.3",
	"description": "Agent-friendly icon package manager: search, add, etch",
	"bin": {
		"sigil": "./src/index.ts"
	},
	"type": "module",
	"scripts": {
		"build": "./scripts/build.sh",
		"check": "bun run typecheck && bun test && bun run fmt:check",
		"test": "bun test",
		"typecheck": "tsgo --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check"
	},
	"dependencies": {
		"@iconify/types": "^2.0.0",
		"@iconify/utils": "^3.1.3",
		"@standard-schema/spec": "^1.1.0",
		"@types/react": "^19.2.17",
		"@valibot/to-json-schema": "^1.7.1",
		"argc": "github:ethan-huo/argc#v6.0.0",
		"react": "^19.2.7",
		"solid-js": "^1.9.13",
		"valibot": "^1.4.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260610.1",
		"oxfmt": "^0.54.0",
		"typescript": "npm:@typescript/typescript6"
	}
}
